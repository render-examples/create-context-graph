# {{ domain.name }} Context Graph Application
# Generated by create-context-graph

.PHONY: start dev dev-backend dev-frontend install seed reset clean test lint

# Start both backend and frontend
start:
	@echo "Starting {{ domain.name }} Context Graph..."
	$(MAKE) dev-backend & $(MAKE) dev-frontend

dev: start

# Backend
dev-backend:
	cd backend && uv run uvicorn app.main:app --reload --port 8000

install-backend:
	cd backend && uv sync

# Frontend
dev-frontend:
	cd frontend && npm run dev

install-frontend:
	cd frontend && npm install

# Install everything
install: install-backend install-frontend

# Seed data into Neo4j
seed:
	cd backend && uv run python scripts/generate_data.py

# Reset Neo4j data (drop and recreate)
reset:
	cd backend && uv run python -c "from app.context_graph_client import reset_database; import asyncio; asyncio.run(reset_database())"

{% if neo4j_type == 'docker' %}
# Docker Neo4j
docker-up:
	docker compose up -d

docker-down:
	docker compose down
{% endif %}

{% if saas_connectors %}
# Data import from connected services
import:
	cd backend && uv run python scripts/import_data.py

import-and-seed: import
	cd backend && uv run python scripts/generate_data.py --ingest
{% endif %}

# Test
test:
	cd backend && uv run python -m pytest tests/ -v 2>/dev/null || echo "No backend tests found"
	cd frontend && npm test 2>/dev/null || echo "No frontend tests found"

# Lint
lint:
	cd backend && uv run ruff check app/ 2>/dev/null || echo "Install ruff for linting: uv pip install ruff"
	cd frontend && npm run lint 2>/dev/null || echo "No frontend lint configured"

# Clean build artifacts
clean:
	rm -rf backend/__pycache__ backend/.venv
	rm -rf frontend/.next frontend/node_modules
