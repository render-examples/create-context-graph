# {{ domain.name }} Context Graph Application
# Generated by create-context-graph

# Neo4j Connection
NEO4J_URI={{ neo4j_uri }}
NEO4J_USERNAME={{ neo4j_username }}
NEO4J_PASSWORD={{ neo4j_password }}

# LLM API Keys
ANTHROPIC_API_KEY={{ anthropic_api_key }}
OPENAI_API_KEY={{ openai_api_key }}
GOOGLE_API_KEY={{ google_api_key }}

# Application
DOMAIN_ID={{ domain.id }}
BACKEND_PORT=8000
FRONTEND_PORT=3000

{% if 'linear' in saas_connectors %}
# Linear (project management data import)
LINEAR_API_KEY=
LINEAR_TEAM=
{% endif %}
# Suppress HuggingFace Hub warnings (set HF_TOKEN for higher rate limits)
HF_HUB_DISABLE_TELEMETRY=1
